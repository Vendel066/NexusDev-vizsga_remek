<Window x:Name="OrderWindowWindow" x:Class="NexusDev_Dashboard.Windows.OrderWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:NexusDev_Dashboard.Windows"
        mc:Ignorable="d"
        Title="Order - #-1"
        Width="1280" Height="720"
        FontSize="14"
        FontFamily="Comic Sans MS"
        Closing="WhenClosing">
    <Window.Background>
        <ImageBrush ImageSource="/Resources/Backgrounds/darkmodebg.png"/>
    </Window.Background>
    <Grid x:Name="OrderGrid">
        <Grid.ColumnDefinitions>
            <ColumnDefinition />
            <ColumnDefinition Width="320" />
        </Grid.ColumnDefinitions>
        <Menu x:Name="OrderMenu" Grid.ColumnSpan="2" VerticalAlignment="Top" Background="Black" Foreground="White" BorderBrush="#FF05F719" FontFamily="Comic Sans MS">
            <MenuItem x:Name="StatusItem" Header="Set Status" Background="Black" Foreground="White" BorderBrush="#FF05F719" FontSize="14">
                <MenuItem x:Name="PendingItem" Header="Pending" Background="Black" Foreground="White" BorderBrush="#FF05F719" Click="PendingItem_Click"/>
                <MenuItem x:Name="InProgressItem" Header="In Progress" Background="Black" Foreground="White" BorderBrush="#FF05F719" Click="InProgressItem_Click"/>
                <MenuItem x:Name="CompletedItem" Header="Completed" Background="Black" Foreground="White" BorderBrush="#FF05F719" Click="CompletedItem_Click"/>
                <MenuItem x:Name="CanceledItem" Header="Canceled" Background="Black" Foreground="White" BorderBrush="#FF05F719" Click="CanceledItem_Click"/>
            </MenuItem>
        </Menu>
        <Border Grid.Column="0" Margin="16,40,8,16" Background="#00111111" CornerRadius="6">
            <Grid Margin="12">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <TextBlock x:Name="OrderTitle" Grid.Row="0" Text="Order Title" FontSize="24" FontWeight="Bold" Foreground="White" HorizontalAlignment="Center" Margin="0,12,0,12" />
                <TextBlock x:Name="OrderDescription" Grid.Row="1" Text="A rövid leírás ide kerül. Itt részletezhető az order tartalma, több sor is megjelenhet." TextWrapping="Wrap" Foreground="White" Margin="8,0,8,12" />
                <Grid Grid.Row="2" Margin="8,0,8,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition />
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="Típus:" Foreground="White" FontWeight="Bold" Grid.Column="0" VerticalAlignment="Center" />
                    <TextBlock x:Name="OrderType" Text="Website" Foreground="White" Grid.Column="1" VerticalAlignment="Center" Margin="6,0,12,0" />
                    <TextBlock Text="Platform:" Foreground="White" FontWeight="Bold" Grid.Column="2" VerticalAlignment="Center" />
                    <TextBlock x:Name="OrderPlatform" Text="Desktop" Foreground="White" Grid.Column="3" VerticalAlignment="Center" Margin="6,0,0,0" />
                </Grid>
                <Grid Grid.Row="3" Margin="8,0,8,8">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <StackPanel Orientation="Horizontal" Grid.Row="0" Margin="0,0,0,8">
                        <TextBlock Text="Budget:" Foreground="White" FontWeight="Bold" VerticalAlignment="Center" />
                        <TextBlock x:Name="OrderBudget" Text="$0" Foreground="White" VerticalAlignment="Center" Margin="6,0,0,0" />
                        <Button x:Name="DownloadDocButton" Content="Dokumentum letöltése" Width="140" Height="28" Margin="16,0,0,0" Background="#FF05F719" Foreground="Black" FontFamily="Comic Sans MS" ToolTip="A dokumentum letöltését végző eljárást a kódoldalon fogod megírni." />
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Grid.Row="1" HorizontalAlignment="Left">
                        <TextBlock Text="Deadline:" Foreground="White" FontWeight="Bold" VerticalAlignment="Center" />
                        <TextBlock x:Name="OrderDeadline" Text="2026-01-01" Foreground="White" VerticalAlignment="Center" Margin="6,0,20,0" />
                        <TextBlock Text="Created at:" Foreground="White" FontWeight="Bold" VerticalAlignment="Center" />
                        <TextBlock x:Name="OrderCreatedAt" Text="2025-12-01" Foreground="White" VerticalAlignment="Center" Margin="6,0,0,0" />
                    </StackPanel>
                </Grid>
            </Grid>
        </Border>
        <Border Grid.Column="1" Margin="8,40,16,16" Background="#CC0B0B0B" CornerRadius="8" BorderBrush="#FF05F719" BorderThickness="1">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="8">
                    <TextBlock Text="Chat" Foreground="White" FontWeight="Bold" FontSize="16" VerticalAlignment="Center"/>
                </StackPanel>
                <ListBox x:Name="ChatMessages" Grid.Row="1" Margin="8" Background="Transparent" Foreground="White" BorderThickness="0" ScrollViewer.VerticalScrollBarVisibility="Auto" />
                <Grid Grid.Row="2" Margin="8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBox x:Name="ChatInput" Grid.Column="0" Height="36" VerticalAlignment="Center" FontFamily="Comic Sans MS" Background="White" Foreground="Black" Margin="0,0,8,0" />
                    <Button x:Name="SendButton" Grid.Column="1" Content="Send" Width="80" Height="36" VerticalAlignment="Center" Background="#FF05F719" Foreground="Black" Click="SendButton_Click" />
                </Grid>
            </Grid>
        </Border>
    </Grid>
</Window>