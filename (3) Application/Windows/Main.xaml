<Window x:Name="MainWindow" x:Class="NexusDev_Dashboard.Windows.Main"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        xmlns:vm="clr-namespace:NexusDev_Dashboard.ViewModels"
        xmlns:sv="clr-namespace:NexusDev_Dashboard.Services"
        xmlns:msc="clr-namespace:NexusDev_Dashboard.Misc"
        Title="Main"
        Width="1280" Height="720"
        FontSize="14"
        FontFamily="Comic Sans MS"
        Closing="WhenClosing">
    <Window.Background>
        <ImageBrush ImageSource="/Resources/Backgrounds/darkmodebg.png"/>
    </Window.Background>
    <Grid x:Name="MainGrid">
        <Menu x:Name="MainMenu" VerticalAlignment="Top" Background="Black" Foreground="White" BorderBrush="#FF05F719" FontFamily="Comic Sans MS">
            <MenuItem x:Name="ApplicationItem" Header="Application" Background="Black" Foreground="White" BorderBrush="#FF05F719" FontSize="14">
                <MenuItem x:Name="HideWindowItem" Header="Hide window" Background="Black" Foreground="White" BorderBrush="#FF05F719" Click="HideWindowItem_Click"/>
                <MenuItem x:Name="CloseApplicationItem" Header="Close Application" Background="Black" Foreground="White" BorderBrush="#FF05F719" Click="CloseApplicationItem_Click"/>
            </MenuItem>
            <MenuItem x:Name="UserItem" Header="User" BorderBrush="#FF05F719" FontSize="14">
                <MenuItem x:Name="LogoutItem" Header="Logout" Background="Black" Foreground="White" BorderBrush="#FF05F719" Click="LogoutItem_Click"/>
            </MenuItem>
            <MenuItem x:Name="ContactItem" Header="Contact" Background="Black" Foreground="White" BorderBrush="#FF05F719" Click="ContactItem_Click" FontSize="14"/>
        </Menu>
        <ListBox x:Name="OrderList" ItemsSource="{Binding Orders}" Background="{x:Null}" Margin="0,21,0,0" BorderBrush="#FF05F719" Foreground="White" SelectionChanged="OrderList_SelectionChanged" />
    </Grid>
</Window>